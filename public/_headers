# Always revalidate the SPA shell + manifest so clients never boot a stale app
# (a stale index.html could reference old assets or a previously-installed start URL).
/
  Cache-Control: no-cache, must-revalidate
/index.html
  Cache-Control: no-cache, must-revalidate
/manifest.webmanifest
  Cache-Control: no-cache, must-revalidate

# Content-hashed build assets are immutable and safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
